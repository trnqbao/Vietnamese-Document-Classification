{
  "manifest_version": 3,
  "name": "Vietnamese Document Classifier",
  "version": "1.0.0",
  "description": "Classify selected Vietnamese text into 10 categories using AI.",
  "permissions": ["activeTab", "scripting", "contextMenus"],
  "host_permissions": ["http://127.0.0.1:8000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vietnamese Document Classifier"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
